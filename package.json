{
  "name": "seqvio",
  "version": "0.1.0",
  "private": true,
  "description": "Seqvio - a simple framework for generative video workflows",
  "keywords": [
    "video",
    "video-generation",
    "react",
    "html5",
    "animation",
    "remotion-alternative",
    "ai-video",
    "programmatic-video",
    "video-framework"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/makesynt/seqvio.git"
  },
  "license": "MIT",
  "author": "Seqvio Team",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present --include-workspace-root=false",
    "build": "npm run build -w @seqvio/core && npm run build -w @seqvio/whiteboard && npm run build -w @seqvio/presentation && npm run build -w @seqvio/renderer",
    "test": "npm run test --workspaces --if-present --include-workspace-root=false",
    "test:visual": "node scripts/visual-regression.mjs",
    "test:visual:update": "node scripts/visual-regression.mjs --update",
    "lint": "npm run lint --workspaces --if-present --include-workspace-root=false",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "npm run clean --workspaces --if-present --include-workspace-root=false",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "puppeteer": "^25.1.0"
  }
}
