# Seqvio reads provider credentials from process environment variables.
# This repository does not auto-load `.env`; copy needed values into your shell,
# CI secret store, or a local loader before running `seqvio-audio synthesize`.

# Default provider selection used by `seqvio-audio synthesize`
SEQVIO_TTS_PROVIDER=elevenlabs

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Edge TTS
EDGE_TTS_VOICE=zh-CN-YunxiNeural
# EDGE_TTS_BIN=

# OpenAI TTS
# OPENAI_API_KEY=
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=tts-1
OPENAI_BASE_URL=https://api.openai.com/v1

# MiniMax
# `mmx auth login` is still required; this only controls the default voice.
# MINIMAX_TTS_VOICE=
