{
  "name": "@seqvio/renderer",
  "version": "0.1.1",
  "description": "Video renderer and audio CLI for Seqvio",
  "keywords": [
    "seqvio",
    "video",
    "renderer",
    "puppeteer",
    "ffmpeg",
    "cli"
  ],
  "license": "MIT",
  "author": "Seqvio Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makesynt/seqvio.git",
    "directory": "packages/renderer"
  },
  "bugs": {
    "url": "https://github.com/makesynt/seqvio/issues"
  },
  "homepage": "https://github.com/makesynt/seqvio#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "seqvio-render": "dist/cli.js",
    "seqvio-audio": "dist/audio-cli.js",
    "seqvio-generate": "dist/generate-cli.js",
    "seqvio-preview": "dist/preview-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "audio:extract-demo": "node dist/audio-cli.js extract --component ../../examples/compositions/seqvio-audio-demo.tsx --out ../../output/seqvio-audio-demo.manifest.json",
    "render:demo": "node dist/cli.js --component ../whiteboard/examples/01-hello-world.tsx --output ../../output/cli-demo.mp4 --width 1280 --height 720 --fps 30 --quality medium",
    "render:smoke": "node dist/cli.js --component ../whiteboard/examples/01-hello-world.tsx --output ../../output/smoke.mp4 --width 640 --height 360 --fps 30 --quality low --duration 60 --pixelRatio 1",
    "render:composition-smoke": "node dist/cli.js --component ../../examples/compositions/seqvio-intro.tsx --output ../../output/composition-smoke.mp4 --width 1280 --height 720 --fps 30 --quality low --pixelRatio 1",
    "render:multiscene-smoke": "node dist/cli.js --component ../core/examples/multi-scene-demo.tsx --output ../../output/multiscene-smoke.mp4 --width 1280 --height 720 --fps 30 --quality low --pixelRatio 1",
    "render:caption-smoke": "node dist/cli.js --component ../../examples/compositions/seqvio-audio-demo.tsx --output ../../output/caption-smoke.mp4 --width 1280 --height 720 --fps 30 --quality low --pixelRatio 1 --burnCaptions"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@seqvio/core": "0.1.1",
    "@seqvio/whiteboard": "0.1.1",
    "esbuild": "^0.25.0",
    "fluent-ffmpeg": "^2.1.3",
    "puppeteer": "^22.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
